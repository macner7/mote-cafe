u03b2\u03ac\u03bd\u03bf\u03c5\u03bd \u03ba\u03b1\u03b9 \u03bd\u03b1 \u03b1\u03c6\u03bf\u03c1\u03bf\u03cd\u03bd \u03cc\u03bb\u03b5\u03c2 \u03c4\u03b9\u03c2 \u03bf\u03bc\u03ac\u03b4\u03b5\u03c2 \u03b1\u03c4\u03cc\u03bc\u03c9\u03bd, \u03b1\u03bd\u03b5\u03be\u03ac\u03c1\u03c4\u03b7\u03c4\u03b1 \u03b1\u03c0\u03cc \u03c3\u03c5\u03b3\u03ba\u03b5\u03ba\u03c1\u03b9\u03bc\u03ad\u03bd\u03b1 \u03c0\u03c1\u03bf\u03c3\u03c9\u03c0\u03b9\u03ba\u03ac \u03c7\u03b1\u03c1\u03b1\u03ba\u03c4\u03b7\u03c1\u03b9\u03c3\u03c4\u03b9\u03ba\u03ac. \u03a3\u03b5 \u03c0\u03bf\u03bb\u03bb\u03ad\u03c2 \u03c0\u03b5\u03c1\u03b9\u03bf\u03c7\u03ad\u03c2 \u03b9\u03c3\u03c7\u03cd\u03bf\u03c5\u03bd \u03bd\u03cc\u03bc\u03bf\u03b9 \u03c0\u03bf\u03c5 \u03b1\u03c0\u03b1\u03b3\u03bf\u03c1\u03b5\u03cd\u03bf\u03c5\u03bd \u03c1\u03b7\u03c4\u03ac \u03c4\u03b9\u03c2 \u03b4\u03b9\u03b1\u03ba\u03c1\u03af\u03c3\u03b5\u03b9\u03c2 \u03b3\u03b9\u03b1 \u03b1\u03c5\u03c4\u03ad\u03c2 \u03c4\u03b9\u03c2 \u03ba\u03b1\u03c4\u03b7\u03b3\u03bf\u03c1\u03af\u03b5\u03c2."),ce=s._(/*BTDS*/"\u0391\u03c0\u03bf\u03b4\u03b5\u03ba\u03c4\u03ae \u03c3\u03c4\u03cc\u03c7\u03b5\u03c5\u03c3\u03b7 \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03af\u03c3\u03b5\u03c9\u03bd"),de=s._(/*BTDS*/"\u03a3\u03c4\u03cc\u03c7\u03b5\u03c5\u03c3\u03b7 \u03b1\u03b3\u03b3\u03b5\u03bb\u03af\u03b1\u03c2 \u03c3\u03c4\u03ad\u03b3\u03b1\u03c3\u03b7\u03c2"),me=s._(/*BTDS*/"\u03a3\u03c4\u03cc\u03c7\u03b5\u03c5\u03c3\u03b7 \u03b4\u03b9\u03b1\u03c6\u03ae\u03bc\u03b9\u03c3\u03b7\u03c2 \u03b3\u03b9\u03b1 \u03b5\u03bd\u03bf\u03b9\u03ba\u03af\u03b1\u03c3\u03b7 \u03b4\u03b9\u03b1\u03bc\u03b5\u03c1\u03af\u03c3\u03bc\u03b1\u03c4\u03bf\u03c2 \u03c3\u03b5 \u03ac\u03c4\u03bf\u03bc\u03b1 \u03c0\u03bf\u03c5 \u03b6\u03bf\u03c5\u03bd \u03b5\u03ba\u03b5\u03af \u03ae \u03ba\u03bf\u03bd\u03c4\u03ac \u03c3\u03c4\u03b7 \u03b3\u03b5\u03bd\u03b9\u03ba\u03ae \u03c4\u03bf\u03c0\u03bf\u03b8\u03b5\u03c3\u03af\u03b1 \u03c4\u03b7\u03c2 \u03b1\u03b3\u03b3\u03b5\u03bb\u03af\u03b1\u03c2."),pe=s._(/*BTDS*/"\u0