 \u03ac\u03c4\u03bf\u03bc\u03b1 \u03ba\u03b1\u03c4\u03ac\u03bb\u03bb\u03b7\u03bb\u03b7\u03c2 \u03b7\u03bb\u03b9\u03ba\u03af\u03b1\u03c2 \u03b5\u03c1\u03b3\u03b1\u03c3\u03af\u03b1\u03c2, \u03b1\u03bd\u03b5\u03be\u03b1\u03c1\u03c4\u03ae\u03c4\u03c9\u03c2 \u03c6\u03cd\u03bb\u03bf\u03c5."),V=s._(/*BTDS*/"\u0394\u03b9\u03b1\u03c6\u03ae\u03bc\u03b9\u03c3\u03b7 \u03c0\u03bf\u03c5 \u03c0\u03c1\u03bf\u03ac\u03b3\u03b5\u03b9 \u03b4\u03b9\u03b1\u03ba\u03c1\u03af\u03c3\u03b5\u03b9\u03c2"),H=s._(/*BTDS*/"\u03a3\u03c4\u03cc\u03c7\u03b5\u03c5\u03c3\u03b7 \u03b4\u03b9\u03b1\u03c6\u03ae\u03bc\u03b9\u03c3\u03b7\u03c2 \u03b3\u03b9\u03b1 \u03b8\u03ad\u03c3\u03b7 \u03b5\u03c1\u03b3\u03b1\u03c3\u03af\u03b1\u03c2 \u03c3\u03b5 \u03ba\u03b1\u03c4\u03ac\u03c3\u03c4\u03b7\u03bc\u03b1 \u03c1\u03bf\u03cd\u03c7\u03c9\u03bd \u03bc\u03b5 \u03c4\u03c1\u03cc\u03c0\u03bf \u03c0\u03bf\u03c5 \u03b1\u03c0\u03bf\u03ba\u03bb\u03b5\u03af\u03b5\u03b9 \u03c4\u03b9\u03c2 \u03b3\u03c5\u03bd\u03b1\u03af\u03ba\u03b5\u03c2 \u03ba\u03b1\u03b9 \u03c4\u03b9\u03c2 \u03b1\u03c0\u03bf\u03c4\u03c1\u03ad\u03c0\u03b5\u03b9 \u03bd\u03b1 \u03c5\u03c0\u03bf\u03b2\u03ac\u03bb\u03bf\u03c5\u03bd \u03b1\u03af\u03c4\u03b7\u03c3\u03b7."),G=s._(/*BTDS*/"\u0396\u03b7\u03c4\u03ae\u03bc\u03b1\u03c4\u03b1 \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03b9\u03b6\u03cc\u03bc\u03b5\u03bd\u03c9\u03bd \u03c0\u03bf\u03c5 \u03c0\u03c1\u03bf\u03b2\u03ac\u03bb\u03bb\u03bf\u03c5\u03bd \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03af\u03c3\u03b5\u03b9\u03c2 \u03b3\u03b9\u03b1 \u03ba\u03b1\u03c4\u03bf\u03b9\u03ba\u03af\u03b5\u03c2, \u03b5\u03c1\u03b3\u03b1\u03c3\u03af\u03b1 \u03ba\u03b1\u03b9 \u03c0\u03b9\u03c3\u03c4\u03c9\u03c4\u03b9\u03ba\u03ad\u03c2 \u03ba\u03ac\u03c1\u03c4\u03b5\u03c2"),z=s._(/*BTDS*/"\u039a\u03c1\u03b9\u03c4\u03ae\u03c1\u03b9\u03b1 \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03b9\u03b6\u03cc\u03bc\u03b5\u03bd\u03c9\u03bd \u03c0\u03bf\u03c5 \u03c0\u03c1\u03bf\u03b2\u03ac\u03bb\u03bb\u03bf\u03c5\u03bd \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03af\u03c3\u03b5\u03b9\u03c2 \u03b3\u03b9\u03b1 \u03b5\u03c5\u03ba\u03b1\u03b9\u03c1\u03af\u03b5\u03c2 \u03c3\u03c4\u03ad\u03b3\u03b1\u03c3\u03b7\u03c2 \u03ae \u03b1\u03c0\u03b1\u03c3\u03c7\u03cc\u03bb\u03b7\u03c3\u03b7\u03c2 \u03ba\u03b1\u03b9 \u03c7\u03c1\u03b7\u03bc\u03b1\u03c4\u03bf\u03bf\u03b9\u03ba\u03bf\u03bd\u03bf\u03bc\u03b9\u03ba\u03ac \u03c0\u03c1\u03bf\u03ca\u03cc\u03bd\u03c4\u03b1 \u03ba\u03b1\u03b9 \u03c5\u03c0\u03b7\u03c1\u03b5\u03c3\u03af\u03b5\u03c2"),j=s._(/*BTDS*/"\u03a0\u03bb\u03ae\u03c1\u03b7\u03c2 \u03c0\u03bf\u03bb\u03b9\u03c4\u03b9\u03ba\u03ae \u03ba\u03b1\u03c4\u03ac \u03c4\u03c9\u03bd \u03b4\u03b9\u03b1\u03ba\u03c1\u03af\u03c3\u03b5\u03c9\u03bd"),K=s._(/*BTDS*/"\u03a0\u03bb\u03ae\u03c1\u03b7\u03c2 \u03c0\u03bf\u03bb\u03b9\u03c4\u03b9\u03ba\u03ae \u03ba\u03b1\u03c4\u03ac \u03c4\u03c9\u03bd \u03b4\u03b9\u03b1\u03ba\u03c1\u03af\u03c3\u03b5\u03c9\u03bd"),Q=s._(/*BTDS*/"\u0397 \u03c0\u03bf\u03bb\u03b9\u03c4\u03b9\u03ba\u03ae \u03ba\u03b1\u03c4\u03ac \u03c4\u03c9\u03bd \u03b4\u03b9\u03b1\u03ba\u03c1\u03af\u03c3\u03b5\u03c9\u03bd \u03c4\u03bf\u03c5 Facebook \u03b5\u03af\u03bd\u03b1\u03b9 \u03ba\u03b1\u03b8\u03bf\u03bb\u03b9\u03ba\u03ae. \u03a9\u03c3\u03c4\u03cc\u03c3\u03bf, \u03ba\u03ac\u03c0\u03bf\u03b9\u03b5\u03c2 \u03c0\u03b5\u03c1\u03b9\u03bf\u03c7\u03ad\u03c2 \u03bc\u03c0\u03bf\u03c1\u03b5\u03af \u03bd\u03b1 \u03ad\u03c7\u03bf\u03c5\u03bd \u03b5\u03c0\u03b9\u03c0\u03bb\u03ad\u03bf\u03bd \u03ba\u03b1\u03bd\u03bf\u03bd\u03b9\u03c3\u03bc\u03bf\u03cd\u03c2. \u0392\u03b5\u03b2\u03b1\u03b9\u03c9\u03b8\u03b5\u03af\u03c4\u03b5 \u03cc\u03c4\u03b9 \u03b1\u03ba\u03bf\u03bb\u03bf\u03c5\u03b8\u03b5\u03af\u03c4\u03b5 \u03c4\u03b7\u03bd \u03b9\u03c3\u03c7\u03cd\u03bf\u03c5\u03c3\u03b1 \u03bd\u03bf\u03bc\u03bf\u03b8\u03b5\u03c3\u03af\u03b1 \u03ae \u03c4\u03b9\u03c2 \u03c0\u03bf\u03bb\u03b9\u03c4\u03b9\u03ba\u03ad\u03c2 \u03b3\u03b9\u03b1 \u03c4\u03b7\u03bd \u03c0\u03b5\u03c1\u03b9\u03bf\u03c7\u03ae \u03c3\u03b1\u03c2 \u03b1\u03bb\u03bb\u03ac \u03ba\u03b1\u03b9 \u03b3\u03b9\u03b1 \u03c4\u03b7\u03bd \u03c0\u03b5\u03c1\u03b9\u03bf\u03c7\u03ae \u03c0\u03bf\u03c5 \u03c3\u03c4\u03bf\u03c7\u03b5\u03cd\u03b5\u03c4\u03b5."),X=s._(/*BTDS*/"\u0397 \u03c0\u03bf\u03bb\u03b9\u03c4\u03b9\u03ba\u03ae \u03ba\u03b1\u03c4\u03ac \u03c4\u03c9\u03bd \u03b4\u03b9\u03b1\u03ba\u03c1\u03af\u03c3\u03b5\u03c9\u03bd \u03c4\u03bf\u03c5 Meta \u03b5\u03af\u03bd\u03b1\u03b9 \u03ba\u03b1\u03b8\u03bf\u03bb\u03b9\u03ba\u03ae, \u03c9\u03c3\u03c4\u03cc\u03c3\u03bf \u03ba\u03ac\u03c0\u03bf\u03b9\u03b5\u03c2 \u03c0\u03b5\u03c1\u03b9\u03bf\u03c7\u03ad\u03c2 \u03bc\u03c0\u03bf\u03c1\u03b5\u03af \u03bd\u03b1 \u03ad\u03c7\u03bf\u03c5\u03bd \u03b5\u03c0\u03b9\u03c0\u03bb\u03ad\u03bf\u03bd \u03ba\u03b1\u03bd\u03bf\u03bd\u03b9\u03c3\u03bc\u03bf\u03cd\u03c2. \u0392\u03b5\u03b2\u03b1\u03b9\u03c9\u03b8\u03b5\u03af\u03c4\u03b5 \u03cc\u03c4\u03b9 \u03b1\u03ba\u03bf\u03bb\u03bf\u03c5\u03b8\u03b5\u03af\u03c4\u03b5 \u03c4\u03b7\u03bd \u03b9\u03c3\u03c7\u03cd\u03bf\u03c5\u03c3\u03b1 \u03bd\u03bf\u03bc\u03bf\u03b8\u03b5\u03c3\u03af\u03b1 \u03ae \u03c4\u03b9\u03c2 \u03c0\u03bf\u03bb\u03b9\u03c4\u03b9\u03ba\u03ad\u03c2 \u03b3\u03b9\u03b1 \u03c4\u03b7\u03bd \u03c0\u03b5\u03c1\u03b9\u03bf\u03c7\u03ae \u03c3\u03b1\u03c2 \u03b1\u03bb\u03bb\u03ac \u03ba\u03b1\u03b9 \u03b3\u03b9\u03b1 \u03c4\u03b7\u03bd \u03c0\u03b5\u03c1\u03b9\u03bf\u03c7\u03ae \u03c0\u03bf\u03c5 \u03c3\u03c4\u03bf\u03c7\u03b5\u03cd\u03b5\u03c4\u03b5."),Y=s._(/*BTDS*/"\u038c\u03c4\u03b1\u03bd \u03c0\u03b1\u03c4\u03ae\u03c3\u03b5\u03c4\u03b5 \"\u0391\u03c0\u03bf\u03b4\u03bf\u03c7\u03ae\", \u03c3\u03b7\u03bc\u03b1\u03af\u03bd\u03b5\u03b9 \u03cc\u03c4\u03b9:"),J=s._(/*BTDS*/"\u03a0\u03b1\u03c4\u03ce\u03bd\u03c4\u03b1\u03c2 \"\u0391\u03c0\u03bf\u03b4\u03bf\u03c7\u03ae\", \u03b4\u03b7\u03bb\u03ce\u03bd\u03b5\u03c4\u03b5 \u03cc\u03c4\u03b9 \u03c3\u03c5\u03bc\u03c6\u03c9\u03bd\u03b5\u03af\u03c4\u03b5 \u03bd\u03b1:"),Z=s._(/*BTDS*/"\u03b8\u03b1 \u03b1\u03ba\u03bf\u03bb\u03bf\u03c5\u03b8\u03b5\u03af \u03c4\u03b9\u03c2 \u03c0\u03bf\u03bb\u03b9\u03c4\u03b9\u03ba\u03ad\u03c2 \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03af\u03c3\u03b5\u03ce\u03bd \u03bc\u03b1\u03c2 \u03ba\u03b1\u03b9 \u03ac\u03bb\u03bb\u03b7 \u03b9\u03c3\u03c7\u03cd\u03bf\u03c5\u03c3\u03b1 \u03bd\u03bf\u03bc\u03bf\u03b8\u03b5\u03c3\u03af\u03b1"),ee=s._(/*BTDS*/"\u0391\u03ba\u03bf\u03bb\u03bf\u03c5\u03b8\u03b5\u03af\u03c4\u03b5 \u03c4\u03b9\u03c2 \u03c0\u03bf\u03bb\u03b9\u03c4\u03b9\u03ba\u03ad\u03c2 \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03af\u03c3\u03b5\u03ce\u03bd \u03bc\u03b1\u03c2 \u03ba\u03b1\u03b9 \u03bf\u03c0\u03bf\u03b9\u03b1\u03b4\u03ae\u03c0\u03bf\u03c4\u03b5 \u03ac\u03bb\u03bb\u03b7 \u03b9\u03c3\u03c7\u03cd\u03bf\u03c5\u03c3\u03b1 \u03bd\u03bf\u03bc\u03bf\u03b8\u03b5\u03c3\u03af\u03b1."),te=s._(/*BTDS*/"\u03b4\u03b5\u03bd \u03ba\u03ac\u03bd\u03b5\u03b9 \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03af\u03c3\u03b5\u03b9\u03c2 \u03bc\u03b5 \u03b4\u03b9\u03b1\u03ba\u03c1\u03af\u03c3\u03b5\u03b9\u03c2"),ne=s._(/*BTDS*/"\u039c\u03b7\u03bd \u03b4\u03b7\u03bc\u03b9\u03bf\u03c5\u03c1\u03b3\u03b5\u03af\u03c4\u03b5 \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03af\u03c3\u03b5\u03b9\u03c2 \u03bc\u03b5 \u03b4\u03b9\u03b1\u03ba\u03c1\u03af\u03c3\u03b5\u03b9\u03c2."),re=s._(/*BTDS*/"\u03a3\u03c5\u03bc\u03c6\u03c9\u03bd\u03ce"),oe=s._(/*BTDS*/"\u0396\u03b7\u03c4\u03ae\u03bc\u03b1\u03c4\u03b1 \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03b9\u03b6\u03cc\u03bc\u03b5\u03bd\u03c9\u03bd \u03c0\u03bf\u03c5 \u03c0\u03c1\u03bf\u03b2\u03ac\u03bb\u03bb\u03bf\u03c5\u03bd \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03af\u03c3\u03b5\u03b9\u03c2 \u03b3\u03b9\u03b1 \u03ba\u03b1\u03c4\u03bf\u03b9\u03ba\u03af\u03b5\u03c2, \u03b5\u03c1\u03b3\u03b1\u03c3\u03af\u03b1 \u03ba\u03b1\u03b9 \u03c0\u03b9\u03c3\u03c4\u03c9\u03c4\u03b9\u03ba\u03ad\u03c2 \u03ba\u03ac\u03c1\u03c4\u03b5\u03c2"),ae=s._(/*BTDS*/"\u039a\u03c1\u03b9\u03c4\u03ae\u03c1\u03b9\u03b1 \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03b9\u03b6\u03cc\u03bc\u03b5\u03bd\u03c9\u03bd \u03c0\u03bf\u03c5 \u03c0\u03c1\u03bf\u03b2\u03ac\u03bb\u03bb\u03bf\u03c5\u03bd \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03af\u03c3\u03b5\u03b9\u03c2 \u03b3\u03b9\u03b1 \u03c3\u03c4\u03ad\u03b3\u03b1\u03c3\u03b7, \u03b5\u03c5\u03ba\u03b1\u03b9\u03c1\u03af\u03b5\u03c2 \u03b1\u03c0\u03b1\u03c3\u03c7\u03cc\u03bb\u03b7\u03c3\u03b7\u03c2 \u03ba\u03b1\u03b9 \u03c7\u03c1\u03b7\u03bc\u03b1\u03c4\u03bf\u03bf\u03b9\u03ba\u03bf\u03bd\u03bf\u03bc\u03b9\u03ba\u03ac \u03c0\u03c1\u03bf\u03ca\u03cc\u03bd\u03c4\u03b1 \u03ba\u03b1\u03b9 \u03c5\u03c0\u03b7\u03c1\u03b5\u03c3\u03af\u03b5\u03c2"),ie=s._(/*BTDS*/"\u0395\u03b9\u03b4\u03b9\u03ba\u03ad\u03c2 \u03c0\u03b5\u03c1\u03b9\u03c0\u03c4\u03ce\u03c3\u03b5\u03b9\u03c2"),le=s._(/*BTDS*/"\u03a0\u03b1\u03c1\u03cc\u03bb\u03bf \u03c0\u03bf\u03c5 \u03b6\u03b7\u03c4\u03ac\u03bc\u03b5 \u03b1\u03c0\u03cc \u03cc\u03bb\u03bf\u03c5\u03c2 \u03c4\u03bf\u03c5\u03c2 \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03b9\u03b6\u03cc\u03bc\u03b5\u03bd\u03bf\u03c5\u03c2 \u03bd\u03b1 \u03b4\u03b9\u03b1\u03b2\u03ac\u03b6\u03bf\u03c5\u03bd \u03ba\u03b1\u03b9 \u03bd\u03b1 \u03b1\u03c0\u03bf\u03b4\u03ad\u03c7\u03bf\u03bd\u03c4\u03b1\u03b9 \u03c4\u03b7\u03bd \u03c0\u03bf\u03bb\u03b9\u03c4\u03b9\u03ba\u03ae \u03bc\u03b1\u03c2 \u03ba\u03b1\u03c4\u03ac \u03c4\u03c9\u03bd \u03b4\u03b9\u03b1\u03ba\u03c1\u03af\u03c3\u03b5\u03c9\u03bd, \u03b7 \u03c0\u03bf\u03bb\u03b9\u03c4\u03b9\u03ba\u03ae \u03b1\u03c5\u03c4\u03ae \u03b5\u03af\u03bd\u03b1\u03b9 \u03b9\u03b4\u03b9\u03b1\u03af\u03c4\u03b5\u03c1\u03b1 \u03c3\u03b7\u03bc\u03b1\u03bd\u03c4\u03b9\u03ba\u03ae \u03b3\u03b9\u03b1 \u03c4\u03bf\u03c5\u03c2 \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03b9\u03b6\u03cc\u03bc\u03b5\u03bd\u03bf\u03c5\u03c2 \u03c0\u03bf\u03c5 \u03c0\u03c1\u03bf\u03b2\u03ac\u03bb\u03bb\u03bf\u03c5\u03bd \u03b4\u03b9\u03b1\u03c6\u03b7\u03bc\u03af\u03c3\u03b5\u03b9\u03c2 \u03b3\u03b9\u03b1 \u03b5\u03c5\u03ba\u03b1\u03b9\u03c1\u03af\u03b5\u03c2 \u03c3\u03c4\u03ad\u03b3\u03b1\u03c3\u03b7\u03c2, \u03b1\u03c0\u03b1\u03c3\u03c7\u03cc\u03bb\u03b7\u03c3\u03b7\u03c2 \u03ae \u03c0\u03a